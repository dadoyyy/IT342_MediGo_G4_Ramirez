# ─── Copy this file and rename it to .env (for reference only) ───────────────
# Spring Boot reads these as environment variables — set them in your IDE
# run configuration or as OS-level environment variables.
#
# DO NOT commit .env or application.properties with real values to git.

# Supabase PostgreSQL (Session Pooler)
DB_URL=jdbc:postgresql://aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres?sslmode=require
DB_USERNAME=postgres.your-project-ref
DB_PASSWORD=your-database-password

# JWT – use a long random string (32+ chars)
JWT_SECRET=replace-with-a-strong-random-secret-string
JWT_EXPIRATION_MS=86400000
